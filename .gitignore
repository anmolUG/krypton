# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# But do not ignore the Next.js source lib directory
!web/src/lib/
!web/src/lib/**
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a PyInstaller
#  specification file to tell PyInstaller where to find lib libraries.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypotheses/
.pytest_cache/
pytestdebug.log

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
IPython_notebook_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the Python version
#   is customized by the setup.py
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not commit Pipfile.lock to libraries.
#   User reports that Pipfile.lock should be committed to apps.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock should be committed to apps, but not libraries.
# poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock should be committed to apps, but not libraries.
# pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# --- Project Specific Ignoring ---

# Models (too large for GitHub)
models/

# Data and logs
data/
error.txt
*.log

# Web artifacts (Next.js)
web/.next/
web/node_modules/
web/.env*
web/out/
web/build/
web/.vercel/
